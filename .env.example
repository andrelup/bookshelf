# Variables de entorno del monorepo BookShelf.
#
# Copia este fichero a `.env` en la raiz del repo (no versionado) y ajusta
# los valores. Lo usan tanto `infra/docker-compose.yml` (via `make dev`)
# como los targets del Makefile que necesitan hablar con la base de datos
# fuera de Docker (`make migrate`, `make seed`).
#
# Es la unica fuente de configuracion del proyecto: no hay un .env por modulo.

# --- Aplicacion ---
APP_NAME=BookShelf API
ENVIRONMENT=development

# --- Base de datos (PostgreSQL 16 + pgvector) ---
# DB_HOST=localhost cuando se ejecuta el backend/alembic directamente en el
# host; dentro de docker compose el servicio "backend" sobreescribe este
# valor a "postgres" automaticamente.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=bookshelf
DB_PASSWORD=change-me-local-dev-password
DB_NAME=bookshelf

# --- Logging ---
LOG_LEVEL=INFO

# --- CORS ---
# Origenes permitidos para llamar a la API desde el navegador, separados
# por comas (p. ej. http://localhost:3000,http://localhost:5173).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
